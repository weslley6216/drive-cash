POSTGRES_HOST=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Transactional email (Resend HTTP API). Only used in production —
# development and test deliver via :test and never call Resend.
RESEND_API_KEY=
MAILER_FROM=no-reply@drivecash.net.br
APP_HOST=drivecash.net.br

# LLM (AI chat). Primary provider + automatic fallback on any Llm::Error.
LLM_PROVIDER=groq
LLM_FALLBACK=gemini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
